# HealthIQ AI v5 - Backend Environment Configuration
# Copy this file to .env and fill in your actual values (backend/.env is gitignored).

# -----------------------------------------------------------------------------
# Local smoke testing (no Postgres)
# -----------------------------------------------------------------------------
# If you do not have a working Postgres URL, leave DATABASE_URL unset or comment
# it out. A stale or wrong cloud URL (e.g. invalid Supabase pooler tenant) causes
# noisy warmup warnings at startup but does not stop the server — remove it for
# a clean local run until you configure a real database.
# DATABASE_URL=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string (omit entirely for API-only local testing without persistence)
# DATABASE_URL=postgresql://username:password@localhost:5432/healthiq_ai_v5

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Database debugging (set to true for development only)
DB_ECHO=false
DB_ECHO_POOL=false

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Required for /api/auth/* (anon client — core/supabase_anon.py). Use real project values.
# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key (for backend operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anonymous key (for frontend operations)
SUPABASE_ANON_KEY=your-anon-key-here

# Storage bucket for exports
SUPABASE_STORAGE_BUCKET=healthiq-exports

# =============================================================================
# GEMINI AI CONFIGURATION
# =============================================================================
# Required for API startup (validated in config/ai.py) — use a real key from Google AI.
# Google AI API key
GEMINI_API_KEY=your-gemini-api-key-here

# Model configuration
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=8192
GEMINI_TIMEOUT=60

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT secret key (generate a strong random key)
SECRET_KEY=your-secret-key-here

# JWT algorithm
JWT_ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
SLOW_QUERY_THRESHOLD=1.0

# Metrics collection
ENABLE_METRICS=true
METRICS_PORT=8001

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Database fallback capabilities
ENABLE_FALLBACK_STORAGE=true
ENABLE_CIRCUIT_BREAKER=true
ENABLE_RETRY_LOGIC=true

# Audit and logging
ENABLE_AUDIT_LOGGING=true

# Export service
ENABLE_EXPORT_SERVICE=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to true for development debugging
DEBUG_SQL=false
DEBUG_QUERIES=false

# Test database URL (for running tests)
# Used only for destructive tests; isolated from production Supabase database
DATABASE_URL_TEST=postgresql://postgres:test@localhost:5433/healthiq_test

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# These should be set in production environment
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# DB_ECHO=false
# DB_ECHO_POOL=false
# DEBUG_SQL=false
# DEBUG_QUERIES=false
